        "\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "df = pd.read_csv('/content/Untitled spreadsheet - Sheet1.csv')\n",
        "\n",
        "\n",
        "print(\"First 5 rows:\")\n",
        "print(df.head())\n",
        "\n",
        "print(\"\\nColumns:\")\n",
        "print(df.columns)\n",
        "\n",
        "\n",
        "df['Likes (Approx)'] = df['Likes (Approx)'].astype(str).str.replace(',', '').astype(int)\n",
        "df['Shares (Approx)'] = df['Shares (Approx)'].astype(str).str.replace(',', '').astype(int)\n",
        "\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "plt.bar(df['Creator / Account'], df['Likes (Approx)'])\n",
        "plt.xticks(rotation=45)\n",
        "plt.title('Likes by Creator')\n",
        "plt.xlabel('Creator')\n",
        "plt.ylabel('Likes')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "\n",
        "plt.figure(figsize=(6,6))\n",
        "df['Category'].value_counts().plot.pie(autopct='%1.1f%%')\n",
        "plt.title('Category Distribution')\n",
        "plt.ylabel('')\n",
        "plt.show()\n",
        "\n",
        "\n",
        "df_sorted = df.sort_values('Year')\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.plot(df_sorted['Year'], df_sorted['Likes (Approx)'], marker='o')\n",
        "plt.title('Likes Over Years')\n",
        "plt.xlabel('Year')\n",
        "plt.ylabel('Likes')\n",
        "plt.grid()\n",
        "plt.show()\n",
        "\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.scatter(df['Likes (Approx)'], df['Shares (Approx)'])\n",
        "plt.title('Likes vs Shares')\n",
        "plt.xlabel('Likes')\n",
        "plt.ylabel('Shares')\n",
        "plt.grid()\n",
        "plt.show()"
