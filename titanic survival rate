    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "\n",
        "df = sns.load_dataset('titanic')\n",
        "\n",
        "\n",
        "print(df.head())\n",
        "print(\"\\nColumns:\", df.columns)\n",
        "\n",
        "\n",
        "df = df[['survived', 'sex', 'pclass', 'age']]\n",
        "\n",
        "\n",
        "df = df.dropna(subset=['age'])\n",
        "\n",
        "\n",
        "gender_survival = df.groupby('sex')['survived'].mean()\n",
        "gender_survival.plot(kind='bar', color=['blue','pink'])\n",
        "plt.title(\"Survival Rate by Gender\")\n",
        "plt.ylabel(\"Survival Rate\")\n",
        "plt.xlabel(\"Gender\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "class_survival = df.groupby('pclass')['survived'].mean()\n",
        "class_survival.plot(kind='bar', color=['green','orange','red'])\n",
        "plt.title(\"Survival Rate by Class\")\n",
        "plt.ylabel(\"Survival Rate\")\n",
        "plt.xlabel(\"Class (1=High, 3=Low)\")\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "plt.scatter(df['age'], df['survived'], alpha=0.5)\n",
        "plt.title(\"Survival vs Age\")\n",
        "plt.xlabel(\"Age\")\n",
        "plt.ylabel(\"Survived (0=No, 1=Yes)\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "df['age_group'] = pd.cut(df['age'], bins=[0,12,18,35,60,100],\n",
        "                         labels=['Child','Teen','Young Adult','Adult','Senior'])\n",
        "\n",
        "age_survival = df.groupby('age_group')['survived'].mean()\n",
        "age_survival.plot(kind='bar', color='purple')\n",
        "plt.title(\"Survival Rate by Age Group\")\n",
        "plt.ylabel(\"Survival Rate\")\n",
        "plt.show()\n",
        "\n",
        "\n",
        "pivot = df.pivot_table(values='survived', index='sex', columns='pclass')\n",
        "pivot.plot(kind='bar')\n",
        "plt.title(\"Survival Rate by Gender and Class\")\n",
        "plt.ylabel(\"Survival Rate\")\n",
        "plt.show()\n",
        "#Histogram of Passengers Ages\n",
        "sns.histplot(df['age'],bins=20,kde=True)\n",
        "plt.title(\"Age Distributions of Titanic Passenger\")\n",
        "plt.xlabel(\"Age\")\n",
        "plt.ylabel(\"Count\")\n",
        "plt.show()\n"
      ],
